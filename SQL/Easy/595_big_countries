-- Problem: 595. Big Countries
-- Difficulty: Easy

-- Approach:
-- A country is considered big if:
-- 1. Its area is greater than or equal to 3,000,000 OR
-- 2. Its population is greater than or equal to 25,000,000
-- We filter rows using OR condition to satisfy either of these criteria.

SELECT name, population, area
FROM World
WHERE area >= 3000000
OR population >=25000000;
